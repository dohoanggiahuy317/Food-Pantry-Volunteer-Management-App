APP_ENV=development
TRUST_REVERSE_PROXY=false
SESSION_COOKIE_SECURE=false
PREFERRED_URL_SCHEME_HTTPS=false
CORS_ALLOWED_ORIGINS=

AUTH_PROVIDER=firebase
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
FIREBASE_ADMIN_CREDENTIALS=backend/firebase_private_key.json

# Optional Google Calendar auto sync. Use the localhost redirect for local dev.
# In production, set this to https://<your-domain>/google-calendar/oauth/callback
# and register the exact same URI in the Google Cloud OAuth client.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5001/google-calendar/oauth/callback

FLASK_SECRET_KEY=huybeo

DATA_BACKEND=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=volunteer_managing
MYSQL_USER=volunteer_user
MYSQL_PASSWORD=volunteer_pass
MYSQL_POOL_SIZE=5
MYSQL_CONNECT_TIMEOUT=10
SEED_MYSQL_FROM_JSON_ON_EMPTY=true

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@updates.example.com
